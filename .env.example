# =====================================================================
# project settings
# =====================================================================
# プロジェクト名
PROJECT_NAME=sample_hp

# ホストUID・GID（自身のホスト環境の値に設定する ※make initで自動設定）
HOST_UID=1000
HOST_GID=1000


# =====================================================================
# frontend
# =====================================================================
# frontコンテナ名
FRONT_CONTAINER=frontend

# ポート
FRONT_PORT=3000


# =====================================================================
# php
# =====================================================================
# phpコンテナ名
PHP_CONTAINER=php
# ポート
PHP_PORT=8000


# =====================================================================
# DB
# =====================================================================
DB_DATABASE=sample_db
DB_USERNAME=sample
DB_PASSWORD=sample
DB_ROOT_PASSWORD=sample_pass


# =====================================================================
# mailhog
# =====================================================================


# =====================================================================
# Nu Html Checker (vnu)
# =====================================================================
# ポート
VNU_PORT=8888


