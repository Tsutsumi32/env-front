#!/bin/sh
#
# Git pre-commit hook
# コミット前にステージングされたJS/SCSS/HTML/PHPファイルに対して
# prettier（およびJSはeslint）を実行してコードを自動整形・修正します
# （Dockerコンテナ内で実行）
#

# ============================================================================
# 初期設定
# ============================================================================

# ============================================================================
# パス・ファイル名の定数
# ============================================================================

DEV_FRONT_DIR="dev-front"
COMPOSE_FILE_NAME="docker-compose.yml"
ENV_FILE_NAME=".env"

RESOURCES_DIR="resources"
HTDOCS_DIR="htdocs"

# コンテナ内の resources 基点（prettier/eslint の実行パス）
CONTAINER_RESOURCES_BASE="/var/www/resources"

# プレフィックス（dev-front 配下 or 通常の resources 配下）
DEV_FRONT_PREFIX_ONLY="${DEV_FRONT_DIR}/"
DEV_FRONT_RESOURCES_PREFIX="${DEV_FRONT_DIR}/${RESOURCES_DIR}/"
RESOURCES_PREFIX="${RESOURCES_DIR}/"

# ファイル種別の抽出パス（grep 用）
JS_DIR_PATH="resources/htdocs/src/js"
SCSS_DIR_PATH="resources/htdocs/src/scss"
RESOURCES_ROOT_PATH="resources"

# grep 用正規表現（末尾の $ はシェル展開を避けるために \$ を使用）
JS_FILE_REGEX="^${JS_DIR_PATH}/.*\\.js\$"
SCSS_FILE_REGEX="^${SCSS_DIR_PATH}/.*\\.scss\$"
HTML_FILE_REGEX="^${RESOURCES_ROOT_PATH}/.*\\.html\$"
PHP_FILE_REGEX="^${RESOURCES_ROOT_PATH}/.*\\.php\$"

# プロジェクトルートディレクトリを取得
ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR" || exit 1

# docker-compose.ymlがあるディレクトリを特定
# ${DEV_FRONT_DIR}/配下にある場合と、ルートにある場合の両方に対応
if [ -f "${DEV_FRONT_DIR}/${COMPOSE_FILE_NAME}" ]; then
  COMPOSE_DIR="$ROOT_DIR/${DEV_FRONT_DIR}"
elif [ -f "${COMPOSE_FILE_NAME}" ]; then
  COMPOSE_DIR="$ROOT_DIR"
else
  echo "❌ docker-compose.ymlが見つかりません"
  exit 1
fi

# ============================================================================
# 環境変数の読み込み
# ============================================================================

# .envファイルから環境変数を読み込む
if [ -f "$COMPOSE_DIR/$ENV_FILE_NAME" ]; then
  set -a
  . "$COMPOSE_DIR/$ENV_FILE_NAME"
  set +a
fi

# Docker Composeサービス名（環境変数から取得、未設定時はfrontendをデフォルト値として使用）
FRONT_CONTAINER="${FRONT_CONTAINER:-frontend}"

# プロジェクト名（環境変数から取得、未設定時はsample_hpをデフォルト値として使用）
PROJECT_NAME="${PROJECT_NAME:-sample_hp}"

# コンテナ名を構築（形式: ${PROJECT_NAME}_${FRONT_CONTAINER}）
CONTAINER_NAME="${PROJECT_NAME}_${FRONT_CONTAINER}"

# ============================================================================
# Dockerコンテナの起動確認
# ============================================================================

cd "$COMPOSE_DIR" || exit 1

# コンテナが起動しているか確認
if ! docker ps --format "{{.Names}}" 2>/dev/null | grep -q "^${CONTAINER_NAME}$"; then
  echo "⚠️  Dockerコンテナが起動していません。起動中..."
  docker compose up -d "${FRONT_CONTAINER}" || exit 1
  sleep 2
fi

cd "$ROOT_DIR" || exit 1

# ============================================================================
# ステージングされたファイルの取得と分類
# ============================================================================

# ステージングされたファイル一覧を取得（追加・変更・マージされたファイルのみ）
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# ステージングされたファイルがない場合は終了
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# JS / SCSS / HTML / PHP ファイルを分類
JS_FILES=""
SCSS_FILES=""
HTML_FILES=""
PHP_FILES=""

for file in $STAGED_FILES; do
  # ${DEV_FRONT_DIR}/プレフィックスを削除して相対パスを取得
  case "$file" in
    ${DEV_FRONT_DIR}/*)
      relative_file="${file#${DEV_FRONT_PREFIX_ONLY}}"
      ;;
    *)
      relative_file="$file"
      ;;
  esac
  
  # JSファイル（${JS_DIR_PATH}/配下）を抽出
  if echo "$relative_file" | grep -q "$JS_FILE_REGEX"; then
    JS_FILES="$JS_FILES $file"
  fi
  
  # SCSSファイル（${SCSS_DIR_PATH}/配下）を抽出
  if echo "$relative_file" | grep -q "$SCSS_FILE_REGEX"; then
    SCSS_FILES="$SCSS_FILES $file"
  fi
  
  # HTMLファイル（resources/配下）を抽出
  if echo "$relative_file" | grep -q "$HTML_FILE_REGEX"; then
    HTML_FILES="$HTML_FILES $file"
  fi
  
  # PHPファイル（resources/配下）を抽出
  if echo "$relative_file" | grep -q "$PHP_FILE_REGEX"; then
    PHP_FILES="$PHP_FILES $file"
  fi
done

# ============================================================================
# SCSSファイルの整形処理
# ============================================================================

if [ -n "$SCSS_FILES" ]; then
  echo "🔧 SCSSファイルを整形中..."
  for file in $SCSS_FILES; do
    # コンテナ内のパスに変換（${DEV_FRONT_DIR}/プレフィックスを削除）
    case "$file" in
      ${DEV_FRONT_DIR}/*)
        relative_file="${file#${DEV_FRONT_RESOURCES_PREFIX}}"
        ;;
      *)
        relative_file="${file#${RESOURCES_PREFIX}}"
        ;;
    esac
    
    # コンテナ内でprettierを実行してファイルを整形
    docker exec "${CONTAINER_NAME}" npx prettier --write "$CONTAINER_RESOURCES_BASE/${relative_file}" || exit 1
    
    # 整形後のファイルをステージングに追加
    git add "$file"
  done
fi

# ============================================================================
# HTMLファイルの整形処理
# ============================================================================

if [ -n "$HTML_FILES" ]; then
  echo "🔧 HTMLファイルを整形中..."
  for file in $HTML_FILES; do
    case "$file" in
      ${DEV_FRONT_DIR}/*)
        relative_file="${file#${DEV_FRONT_RESOURCES_PREFIX}}"
        ;;
      *)
        relative_file="${file#${RESOURCES_PREFIX}}"
        ;;
    esac
    docker exec "${CONTAINER_NAME}" npx prettier --write "$CONTAINER_RESOURCES_BASE/${relative_file}" || exit 1
    git add "$file"
  done
fi

# ============================================================================
# PHPファイルの整形処理
# ============================================================================

if [ -n "$PHP_FILES" ]; then
  echo "🔧 PHPファイルを整形中..."
  for file in $PHP_FILES; do
    case "$file" in
      ${DEV_FRONT_DIR}/*)
        relative_file="${file#${DEV_FRONT_RESOURCES_PREFIX}}"
        ;;
      *)
        relative_file="${file#${RESOURCES_PREFIX}}"
        ;;
    esac
    docker exec "${CONTAINER_NAME}" npx prettier --write "$CONTAINER_RESOURCES_BASE/${relative_file}" || exit 1
    git add "$file"
  done
fi

# ============================================================================
# JSファイルの整形・修正処理
# ============================================================================

if [ -n "$JS_FILES" ]; then
  # prettierでJSファイルを整形
  echo "🔧 JSファイルを整形中..."
  for file in $JS_FILES; do
    # コンテナ内のパスに変換（${DEV_FRONT_DIR}/プレフィックスを削除）
    case "$file" in
      ${DEV_FRONT_DIR}/*)
        relative_file="${file#${DEV_FRONT_RESOURCES_PREFIX}}"
        ;;
      *)
        relative_file="${file#${RESOURCES_PREFIX}}"
        ;;
    esac
    
    # コンテナ内でprettierを実行してファイルを整形
    docker exec "${CONTAINER_NAME}" npx prettier --write "$CONTAINER_RESOURCES_BASE/${relative_file}" || exit 1
    
    # 整形後のファイルをステージングに追加
    git add "$file"
  done
  
  # eslintでJSファイルを修正
  echo "🔧 JSファイルをESLintで修正中..."
  for file in $JS_FILES; do
    # コンテナ内のパスに変換（${DEV_FRONT_DIR}/プレフィックスを削除）
    case "$file" in
      ${DEV_FRONT_DIR}/*)
        relative_file="${file#${DEV_FRONT_RESOURCES_PREFIX}}"
        ;;
      *)
        relative_file="${file#${RESOURCES_PREFIX}}"
        ;;
    esac
    
    # コンテナ内でeslint --fixを実行して自動修正
    docker exec "${CONTAINER_NAME}" npx eslint --fix "$CONTAINER_RESOURCES_BASE/${relative_file}" || exit 1
    
    # 修正後のファイルをステージングに追加
    git add "$file"
  done
fi

exit 0